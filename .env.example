# Copiar a .env y completar valores reales.

# --- Base de datos (una de las dos formas) ---
# DATABASE_URL=postgresql://user:pass@host:5432/dbname
DB_HOST=localhost
DB_PORT=5432
DB_NAME=postgres
DB_USER=om_read
DB_PASSWORD=

# --- Altiplano (potencias TX/RX; opcional si no usás consultas que llamen a la API) ---
ALTIPLANO_USER=
ALTIPLANO_PASSWORD=
# Caducidad del token cacheado en memoria (segundos). 0 = solo renovar ante 401/403. Default ~55 min.
# ALTIPLANO_TOKEN_CACHE_MAX_AGE_SECONDS=3300
# Sesión Flask del panel Altiplano (/dashboard/altiplano). Default 3600 s (1 h).
# ORQUESTADOR_SESSION_TTL_SECONDS=3600
# Sesión Altiplano en el navegador (consulta: bajar PON / cambiar SN / perfiles HSI). Default 600 s (10 min).
# CONSULTA_ALTIPLANO_UI_CACHE_SECONDS=600
# RAMAs/CTOs en paralelo en consulta masiva (fetch /potencias). Default 32.
# CONSULTA_POTENCIAS_PARALLEL_MAX=32
# Lotes /potencias/batch simultáneos en el navegador (precarga masiva). Default 1 en JS.
# CONSULTA_POTENCIAS_PRELOAD_BATCH_WORKERS=1
# RAMAs en paralelo dentro de cada POST /potencias/batch. Default 4. <= DB_POOL_MAX - 2.
# CONSULTA_POTENCIAS_BATCH_WORKERS=4
# Paralelismo Altiplano en consulta masiva (más bajo que consulta manual).
# ALTIPLANO_POWER_CTO_WORKERS_MASIVO=2
# ALTIPLANO_POWER_WORKERS_MASIVO=8
# Consulta manual / dashboards (valores normales).
# ALTIPLANO_POWER_CTO_WORKERS=8
# ALTIPLANO_POWER_WORKERS=24
# Credenciales por operador (preferidas para acciones NBI: cambio SN / ont-connection).
# ALTIPLANO_TASA_USER=
# ALTIPLANO_TASA_PASSWORD=
# ALTIPLANO_INP_USER=
# ALTIPLANO_INP_PASSWORD=
# ALTIPLANO_DTV_USER=
# ALTIPLANO_DTV_PASSWORD=
# ALTIPLANO_METRO_USER=
# ALTIPLANO_METRO_PASSWORD=
# ALTIPLANO_IPLAN_USER=
# ALTIPLANO_IPLAN_PASSWORD=
# ALTIPLANO_ATC_USER=
# ALTIPLANO_ATC_PASSWORD=
# ALTIPLANO_SION_USER=
# ALTIPLANO_SION_PASSWORD=
# Override opcional de endpoint NBI por operador:
# ALTIPLANO_TASA_HOST=10.200.4.101
# ALTIPLANO_TASA_PORT=32443
# ALTIPLANO_TASA_BASE_URL=tasa-altiplano-ac
# ALTIPLANO_INP_HOST=10.200.3.100
# ALTIPLANO_INP_PORT=32443
# ALTIPLANO_INP_BASE_URL=inp-altiplano-ac

# --- Web ToolBox FTTH Norte (VNO · Cambio de CTO / SendFTTH) ---
# FTTH_TOOLBOX_BASE_URL=https://ar-toolbox.simpledatacorp.com
# FTTH_TOOLBOX_USER=
# FTTH_TOOLBOX_PASSWORD=
# ID de aliado ATC en el mantenedor (default 8)
# FTTH_TOOLBOX_ALLY_ATC_ID=8

# --- Flask ---
# Modo mantenimiento: 1 = pantalla de portada (503); 0 = suite operativa (reiniciar contenedor tras cambiar).
# MAINTENANCE_MODE=0
# Texto del título en la pantalla de mantenimiento (default: En mantenimiento).
# MAINTENANCE_MESSAGE=En mantenimiento
SECRET_KEY=dev-only-change-in-production
FLASK_HOST=0.0.0.0
FLASK_PORT=9000
FLASK_DEBUG=1

# --- Docker (docker-compose.yml) ---
# Puerto publicado en el host (mapeo host:contenedor → NOC_SUITE_PUBLISH_PORT:9000). Default 9000.
# NOC_SUITE_PUBLISH_PORT=9000

# Logo del splash (ruta bajo static/): pictograma sin letras. Por defecto splash-mark.png (RGBA).
# SPLASH_LOGO_PATH=img/splash-mark.svg

# Pool psycopg2
DB_POOL_MIN=2
DB_POOL_MAX=10
DB_CONNECT_TIMEOUT_SECS=5
DB_STATEMENT_TIMEOUT_MS=30000
DB_IDLE_IN_TXN_TIMEOUT_MS=15000
DB_APP_NAME=atc-noc-suite

# Caché en memoria de los árboles de dashboard que leen Postgres (RAMA / OLT).
# Default 120 s. Invalidación solo por expiración (TTL).
# DASHBOARD_TREE_CACHE_SECONDS aplica a ambos si no definís overrides por dashboard.
DASHBOARD_TREE_CACHE_SECONDS=120
# Opcionales (tienen prioridad sobre DASHBOARD_TREE_CACHE_SECONDS):
# DASHBOARD_RAMA_CACHE_SECONDS=120
# DASHBOARD_OLT_CACHE_SECONDS=120
# Potencias Altiplano en vivo (CTO / RAMA dashboard). Default 45 s.
# DASHBOARD_POWER_CACHE_SECONDS=45
# Histórico potencias (solo lectura Postgres altiplano.potencias). Default 600 s.
# DASHBOARD_HISTORICO_CACHE_SECONDS=600
# Workers paralelos al calcular Radar Degradacion (lectura potencias por OLT; default 6)
# RADAR_DEGRADACION_OLT_WORKERS=6
# Timeout por consulta OLT en ms (default 90000; el global suele ser 30000)
# RADAR_DEGRADACION_STATEMENT_TIMEOUT_MS=90000
# Calidad inventario (KPI resumen + conciliación). Default = DASHBOARD_TREE_CACHE_SECONDS.
# DASHBOARD_CALIDAD_CACHE_SECONDS=120

# Estadísticas Clientes ATC (caché altas/bajas desde Postgres aux.*). Default 3600 s.
# INVENTARIO_ESTADISTICAS_CACHE_SECONDS=3600

# --- Camino óptico · mapa por rama (PostGIS / esquema cm; opcional) ---
# CAMINO_GIS_CM_SCHEMA=cm
# CAMINO_GIS_CI_OP_TABLE=ci_op
# Puntos FAT / CTO para marcar en mapa si no hay coordenadas en aux.bajada_inventario:
# CAMINO_GIS_SFAT_TABLE=ci_sfat_mfat_bfat
# Si la columna geom tiene SRID=0 en geometry_columns pero los datos están en p. ej. POSGAR:
# CAMINO_GIS_ASSUME_SRID=5347
# Botellas / FOSC en mapa masivo (PostGIS cm.ci_fosc):
# CAMINO_GIS_FOSC_TABLE=ci_fosc
# Distancia máxima FOSC al trazado unificado (m) y radio snap del corte a botella (m):
# CAMINO_GIS_FOSC_MAX_DIST_TRAZ_M=100
# CAMINO_GIS_FOSC_MAX_SNAP_M=200
# CAMINO_GIS_FOSC_MAP_LIMIT=150
# Feeder distribution (paso QGIS ci_feeder_distribution ∩ ci_op → corte 144):
# CAMINO_GIS_FEEDER_DIST_TABLE=ci_feeder_distribution
# CAMINO_GIS_FEEDER_MAX_DIST_TRAZ_M=800
# CAMINO_GIS_FEEDER_FOSC_CORTE_M=120
# Verificación planta interna (PDF / ticket: SF01-R1301-010 → report_fusiones):
# CAMINO_GIS_FUSIONES_TABLE=report_fusiones
# CAMINO_GIS_FUSIONES_LIMIT=30
