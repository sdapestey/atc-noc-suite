# Copiar a .env y completar valores reales.

# --- Base de datos (una de las dos formas) ---
# DATABASE_URL=postgresql://user:pass@host:5432/dbname
DB_HOST=localhost
DB_PORT=5432
DB_NAME=postgres
DB_USER=om_read
DB_PASSWORD=

# --- Altiplano (potencias TX/RX; opcional si no usás consultas que llamen a la API) ---
ALTIPLANO_USER=
ALTIPLANO_PASSWORD=
# Credenciales por operador (preferidas para acciones NBI: cambio SN / ont-connection).
# ALTIPLANO_TASA_USER=
# ALTIPLANO_TASA_PASSWORD=
# ALTIPLANO_INP_USER=
# ALTIPLANO_INP_PASSWORD=
# ALTIPLANO_DTV_USER=
# ALTIPLANO_DTV_PASSWORD=
# ALTIPLANO_METRO_USER=
# ALTIPLANO_METRO_PASSWORD=
# ALTIPLANO_IPLAN_USER=
# ALTIPLANO_IPLAN_PASSWORD=
# ALTIPLANO_ATC_USER=
# ALTIPLANO_ATC_PASSWORD=
# ALTIPLANO_SION_USER=
# ALTIPLANO_SION_PASSWORD=
# Override opcional de endpoint NBI por operador:
# ALTIPLANO_TASA_HOST=10.200.4.101
# ALTIPLANO_TASA_PORT=32443
# ALTIPLANO_TASA_BASE_URL=tasa-altiplano-ac
# ALTIPLANO_INP_HOST=10.200.3.100
# ALTIPLANO_INP_PORT=32443
# ALTIPLANO_INP_BASE_URL=inp-altiplano-ac

# --- Flask ---
SECRET_KEY=dev-only-change-in-production
FLASK_HOST=0.0.0.0
FLASK_PORT=9002
FLASK_DEBUG=1

# Pool psycopg2
DB_POOL_MIN=2
DB_POOL_MAX=10
DB_CONNECT_TIMEOUT_SECS=5
DB_STATEMENT_TIMEOUT_MS=30000
DB_IDLE_IN_TXN_TIMEOUT_MS=15000
DB_APP_NAME=gpon-inventory

# Caché en memoria de los árboles de dashboard que leen Postgres (RAMA / OLT).
# Default 120 s. Invalidación solo por expiración (TTL).
# DASHBOARD_TREE_CACHE_SECONDS aplica a ambos si no definís overrides por dashboard.
DASHBOARD_TREE_CACHE_SECONDS=120
# Opcionales (tienen prioridad sobre DASHBOARD_TREE_CACHE_SECONDS):
# DASHBOARD_RAMA_CACHE_SECONDS=120
# DASHBOARD_OLT_CACHE_SECONDS=120
